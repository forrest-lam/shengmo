# 腾讯云 ASR 配置
TENCENT_SECRET_ID=your_secret_id_here
TENCENT_SECRET_KEY=your_secret_key_here
TENCENT_APPID=your_appid_here

# 可选：OpenAI API 用于 LLM 后处理（文本润色）
LLM_API_KEY=your_llm_api_key_here
